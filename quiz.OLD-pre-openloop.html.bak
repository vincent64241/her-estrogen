<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Get approved — HerEstrogen</title>
<link rel="icon" type="image/png" sizes="32x32" href="assets/favicon-32.png?v=3" />
<link rel="icon" type="image/png" sizes="16x16" href="assets/favicon-16.png?v=3" />
<link rel="apple-touch-icon" sizes="180x180" href="assets/apple-touch-icon.png?v=3" />
<link rel="shortcut icon" href="assets/favicon-32.png?v=3" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..600&family=DM+Sans:opsz,wght@9..40,300..700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #b8235c; --pink-2: #d04a7e; --pink-3: #ec84a8;
    --pink-soft: #fde8ef; --pink-softer: #fef5f8; --pink-deep: #8a1745;
    --ink: #1a1216; --ink-2: #3d2b33; --muted: #7a6770;
    --line: #f0d9e2; --line-2: #e8c5d2;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background:
      radial-gradient(900px 600px at 90% 0%, var(--pink-soft) 0%, transparent 55%),
      radial-gradient(700px 500px at 0% 100%, var(--pink-softer) 0%, transparent 55%),
      #fff;
    color: var(--ink);
    font-family: 'DM Sans', system-ui, sans-serif;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; padding: 0; color: inherit; }

  .top {
    display: flex; justify-content: space-between; align-items: center;
    padding: 18px 32px;
    border-bottom: 1px solid var(--line);
    background: rgba(255,255,255,.85);
    backdrop-filter: blur(10px);
  }
  .top img { height: 80px; width: auto; display: block; }
  .top-back {
    font-size: 14px; color: var(--ink-2); font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .top-back:hover { color: var(--pink); }

  .shell {
    max-width: 640px; margin: 0 auto;
    padding: 48px 32px 96px;
  }
  .progress-shell {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 40px;
    font-family: 'DM Mono', monospace; font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted);
  }
  .progress-bar {
    flex: 1; height: 6px; background: var(--pink-soft);
    border-radius: 999px; overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--pink) 0%, var(--pink-deep) 100%);
    transition: width .4s cubic-bezier(.4,0,.2,1);
  }

  .step h1 {
    font-family: 'Lora', serif; font-weight: 500;
    font-size: clamp(32px, 4.4vw, 48px); line-height: 1.05;
    letter-spacing: -0.022em;
    margin: 0 0 14px;
  }
  .step h1 em { font-style: italic; color: var(--pink); }
  .step-intro {
    font-size: 17px; color: var(--ink-2); line-height: 1.55;
    margin: 0 0 32px;
  }

  .choices { display: flex; flex-direction: column; gap: 10px; }
  .choice {
    width: 100%; text-align: left;
    background: #fff; border: 1px solid var(--line);
    border-radius: 10px;
    padding: 18px 20px;
    font-size: 16px; font-weight: 500; color: var(--ink);
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    transition: all .15s ease;
  }
  .choice:hover { border-color: var(--pink-3); box-shadow: 0 4px 14px rgba(184,35,92,.07); }
  .choice.selected {
    background: linear-gradient(135deg, var(--pink) 0%, var(--pink-deep) 100%);
    color: #fff; border-color: var(--pink);
    box-shadow: 0 8px 22px rgba(184,35,92,.22);
  }
  .choice .check {
    width: 22px; height: 22px; border-radius: 50%;
    border: 1.5px solid var(--line-2); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: transparent; font-size: 13px;
  }
  .choice.selected .check {
    background: #fff; border-color: #fff; color: var(--pink);
  }
  .choice-note {
    font-size: 12px; color: var(--muted); font-weight: 400;
    margin-top: 4px;
  }
  .choice.selected .choice-note { color: rgba(255,255,255,.8); }

  .field {
    display: flex; flex-direction: column; gap: 12px;
  }
  .field label {
    font-family: 'DM Mono', monospace; font-size: 11px;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--pink);
  }
  .field input {
    background: #fff; border: 1px solid var(--line);
    border-radius: 10px; padding: 16px 18px;
    font-family: inherit; font-size: 16px; color: var(--ink);
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .field input:focus {
    outline: none; border-color: var(--pink);
    box-shadow: 0 0 0 4px rgba(184,35,92,.12);
  }
  /* Birthday — three Month/Day/Year dropdowns sharing the .field styling */
  .field .helper {
    font-family: inherit; font-size: 13px; color: var(--ink-2);
    margin-top: -4px; line-height: 1.4;
  }
  .field-row3 {
    display: grid; grid-template-columns: 1.4fr 1fr 1.1fr; gap: 10px;
  }
  .field-row3 select {
    background: #fff; border: 1px solid var(--line);
    border-radius: 10px; padding: 16px 14px;
    font-family: inherit; font-size: 16px; color: var(--ink);
    appearance: none; -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'><path d='M1 1.5L6 6.5L11 1.5' stroke='%23b8235c' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
    cursor: pointer;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .field-row3 select:focus {
    outline: none; border-color: var(--pink);
    box-shadow: 0 0 0 4px rgba(184,35,92,.12);
  }
  .field-error {
    font-size: 13px; color: var(--pink-deep);
    margin-top: 2px;
  }

  .actions {
    margin-top: 40px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 24px; border-radius: 999px;
    font-size: 15px; font-weight: 600;
    transition: all .2s ease; white-space: nowrap;
  }
  .btn-primary {
    background: var(--pink); color: #fff;
    box-shadow: 0 4px 18px rgba(184,35,92,.22);
  }
  .btn-primary:hover:not(:disabled) { background: var(--pink-deep); }
  .btn-primary:disabled { opacity: .4; cursor: not-allowed; box-shadow: none; }
  .btn-back {
    background: transparent; color: var(--muted); font-weight: 500;
  }
  .btn-back:hover { color: var(--ink); }

  .symptom-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;
  }
  .symptom-grid .choice { padding: 14px 16px; font-size: 14px; }

  .footnote {
    margin-top: 28px;
    font-family: 'DM Mono', monospace; font-size: 11px;
    color: var(--muted); letter-spacing: 0.06em;
    display: flex; align-items: center; gap: 8px;
  }
  .footnote::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--pink);
  }

  /* finish */
  .finish { text-align: center; padding: 32px 0; }
  .finish-badge {
    width: 72px; height: 72px; border-radius: 50%;
    background: var(--pink-soft);
    color: var(--pink); font-size: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
  }
  .finish h1 { font-family: 'Lora', serif; font-weight: 500;
    font-size: 44px; letter-spacing: -0.02em; margin: 0 0 12px; }
  .finish h1 em { font-style: italic; color: var(--pink); }
  .finish p { font-size: 17px; color: var(--ink-2); max-width: 440px; margin: 0 auto 28px; }
</style>
<!-- Compliance audit C-08 / HHS OCR tracking-tech guidance (Dec 2022; rev
     Mar 2024): NO Meta Pixel, NO Google Analytics, NO Vercel Web Analytics
     on this page or any other health-context URL (quiz, results,
     confirmation, privacy, terms). Re-enabling on this page requires
     counsel review + a written Klaviyo / Meta healthcare-policy
     determination. Marketing attribution may be added later via the
     server-side Meta Conversions API keyed off de-identified pseudonyms
     created AFTER an explicit consent gate.
     Stub helpers below are no-ops so callers in the React tree don't crash. -->
<script>
window.trackCompleteRegistration = function () { /* tracker disabled per compliance audit */ };
window.trackInitiateCheckout = function () { /* tracker disabled per compliance audit */ };
</script>
<meta name="robots" content="noindex, nofollow">
</head>
<body>

<div class="top">
  <a href="index.html" aria-label="HerEstrogen home"><img src="assets/logo.png" alt="HerEstrogen" /></a>
  <a class="top-back" href="index.html">← Back to home</a>
</div>

<div id="root"></div>

<template id="__bundler_thumbnail">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
    <defs>
      <radialGradient id="bg" cx="50%" cy="40%" r="70%">
        <stop offset="0%" stop-color="#fde8ef"/>
        <stop offset="100%" stop-color="#ec84a8"/>
      </radialGradient>
    </defs>
    <rect width="200" height="200" fill="url(#bg)"/>
    <text x="100" y="118" text-anchor="middle" font-family="Lora, Georgia, serif" font-style="italic" font-size="64" font-weight="500" fill="#b8235c">Her</text>
  </svg>
</template>

<script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
<script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
<script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>

<script type="text/babel">
const { useState } = React;

const STEPS = [
  {
    kind: 'single', key: 'stage',
    title: 'Where are you in the menopause journey?',
    intro: "We use this to match you with a clinician who treats women in your stage every day.",
    options: [
      { v: 'peri',  label: 'Perimenopause',   note: 'Cycles still present but shifting' },
      { v: 'meno',  label: 'Menopause',       note: '12+ months without a period' },
      { v: 'post',  label: 'Postmenopause',   note: 'A few years past my last period' },
      { v: 'unsure', label: "I'm not sure",   note: "That's okay — we'll help figure it out" },
    ],
  },
  {
    kind: 'multi', key: 'symptoms',
    title: 'Which symptoms have you noticed?',
    intro: 'Tap anything you have experienced in the last six months. There are no wrong answers.',
    options: [
      { v: 'hot',   label: 'Hot flashes' },
      { v: 'sleep', label: 'Sleep disruption' },
      { v: 'mood',  label: 'Mood shifts' },
      { v: 'brain', label: 'Brain fog' },
      { v: 'sex',   label: 'Low libido' },
      { v: 'skin',  label: 'Dry skin & hair' },
      { v: 'weight',label: 'Weight & energy' },
      { v: 'cycle', label: 'Irregular cycles' },
    ],
    grid: true,
  },
  {
    kind: 'single', key: 'tried',
    title: 'Have you tried hormone therapy before?',
    intro: 'Whatever your history, your clinician will start from where you are.',
    options: [
      { v: 'never',   label: 'Never' },
      { v: 'past',    label: 'Yes, in the past' },
      { v: 'current', label: 'Currently on it' },
      { v: 'unsure',  label: 'Not sure' },
    ],
  },
  {
    kind: 'single', key: 'preference',
    title: 'Which form of treatment do you prefer?',
    intro: 'Hormone therapy can be delivered in different ways. Pick what fits your lifestyle — your provider can always adjust.',
    options: [
      { v: 'gel',       label: 'Cream or gel',           note: 'Daily — applied to skin' },
      { v: 'patch',     label: 'Patch',                  note: 'Twice weekly — set and forget' },
      { v: 'vaginal',   label: 'Vaginal insert',         note: 'For local symptoms only' },
      { v: 'effective', label: "I'm not picky — give me the most effective option", note: 'Let our clinician choose the best protocol for you' },
    ],
  },
  {
    kind: 'contact',
    title: 'Where should we send your results?',
    intro: 'We use your email to send your candidacy summary and the link to finish your medical intake. SMS opt-in is shown below — it is optional and never a condition of purchase.',
  },
];

function formatPhone(value) {
  const digits = (value || '').replace(/\D/g, '').slice(0, 10);
  if (digits.length === 0) return '';
  if (digits.length < 4) return `(${digits}`;
  if (digits.length < 7) return `(${digits.slice(0,3)}) ${digits.slice(3)}`;
  return `(${digits.slice(0,3)}) ${digits.slice(3,6)}-${digits.slice(6)}`;
}

// ===== Birthday helpers (optional field; partial fills are rejected) =====
const MONTHS = [
  '', 'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December'
];
const BIRTH_YEAR_MAX = new Date().getFullYear() - 21;  // gate minors / impossibly young
const BIRTH_YEAR_MIN = 1940;
const BIRTH_YEARS = (() => {
  const arr = [];
  for (let y = BIRTH_YEAR_MAX; y >= BIRTH_YEAR_MIN; y--) arr.push(y);
  return arr;
})();
// Days vary by (month, year). Returns 0 if month not set yet.
function daysInMonth(month, year) {
  if (!month) return 0;
  const m = parseInt(month, 10);
  const y = year ? parseInt(year, 10) : 2000; // leap-safe default for picker before year chosen
  return new Date(y, m, 0).getDate();
}
// Validate the three-piece birthday. Returns one of:
//   { state: 'empty' }         — all three blank, valid (field is optional)
//   { state: 'partial' }       — some but not all filled, invalid
//   { state: 'ok', iso }       — fully filled + a real calendar date in range
//   { state: 'invalid' }       — fully filled but not a real date
function validateBirthday(b) {
  const m = (b && b.month) || '';
  const d = (b && b.day) || '';
  const y = (b && b.year) || '';
  const filledCount = [m, d, y].filter(Boolean).length;
  if (filledCount === 0) return { state: 'empty' };
  if (filledCount < 3) return { state: 'partial' };
  const mi = parseInt(m, 10), di = parseInt(d, 10), yi = parseInt(y, 10);
  if (yi < BIRTH_YEAR_MIN || yi > BIRTH_YEAR_MAX) return { state: 'invalid' };
  const dt = new Date(yi, mi - 1, di);
  if (dt.getFullYear() !== yi || dt.getMonth() !== mi - 1 || dt.getDate() !== di) {
    return { state: 'invalid' };
  }
  const iso = `${yi}-${String(mi).padStart(2, '0')}-${String(di).padStart(2, '0')}`;
  return { state: 'ok', iso };
}

// =====================================================================
// Sticky draft — persist partial quiz answers to localStorage so the
// user re-hydrates on reload AND we can replay them as Klaviyo profile
// properties the instant we capture an email.
//
// Key: `herestrogen_quiz_draft`. Cleared on successful submit. Expires
// after 7 days so stale drafts don't haunt return visits months later.
// =====================================================================
const DRAFT_KEY = 'herestrogen_quiz_draft';
const DRAFT_TTL_MS = 7 * 24 * 60 * 60 * 1000;

function loadDraft() {
  try {
    const raw = localStorage.getItem(DRAFT_KEY);
    if (!raw) return null;
    const parsed = JSON.parse(raw);
    if (!parsed || typeof parsed !== 'object') return null;
    if (!parsed.savedAt || (Date.now() - parsed.savedAt) > DRAFT_TTL_MS) {
      localStorage.removeItem(DRAFT_KEY);
      return null;
    }
    return parsed;
  } catch (e) {
    return null;
  }
}
function saveDraft(answers, idx) {
  try {
    localStorage.setItem(DRAFT_KEY, JSON.stringify({
      answers: answers || {},
      idx: typeof idx === 'number' ? idx : 0,
      savedAt: Date.now()
    }));
  } catch (e) { /* storage disabled — silently no-op */ }
}
function clearDraft() {
  try { localStorage.removeItem(DRAFT_KEY); } catch (e) {}
}

// Build a sanitized set of Klaviyo profile properties from in-progress
// quiz answers. Same compliance locks as /api/quiz/submit — opaque slugs
// only (e.g. "peri", "hot"), never the human-readable medical strings.
function buildDraftProfileProps(answers) {
  const props = { source: 'quiz', quiz_in_progress: true };
  if (!answers) return props;
  if (answers.stage) props.hormone_stage = answers.stage;
  if (Array.isArray(answers.symptoms) && answers.symptoms.length > 0) {
    props.primary_symptom = answers.symptoms[0];
    props.symptom_score = answers.symptoms.length;
  }
  if (answers.tried) props.tried_hrt = answers.tried;
  if (answers.preference) props.preference = answers.preference;
  return props;
}

// =====================================================================
// Klaviyo integration — public client-side subscription
// =====================================================================
// company_id and list_id are PUBLIC (used in browser). Safe to commit.
// Replace these placeholder strings with values from Klaviyo Dashboard:
//   - company_id: Account → Settings → API Keys → "Public API Key (Company ID)"
//   - list_id:    Lists & Segments → click your list → "List ID" in URL or settings
const KLAVIYO_COMPANY_ID = 'RUvm7K';
const KLAVIYO_LIST_ID    = 'Rsp58u';

// ⚠ HIPAA: only flip this to true after Klaviyo signs you a BAA in writing.
//   When false, we send ONLY email + first name + quiz_completed flag
//   (no symptoms, stage — those stay in Supabase only).
const KLAVIYO_SEND_HEALTH_DATA = false;

// =====================================================================
// Started Quiz event — fires client-side via Klaviyo's /client/events/
// endpoint (public, uses company_id; no private key needed).
//
// Fires the first time a user types a VALID email in the contact step.
// Triggers F1 Quiz Abandonment in Klaviyo. If the user goes on to submit
// the quiz within 1 hour, /api/quiz/submit fires a "Completed Quiz" event
// which is F1's exit signal — so the abandonment emails never go out.
//
// We dedupe via localStorage so re-entering the page doesn't re-fire.
// =====================================================================
// We attach the in-progress draft answers as profile properties on the
// same call — this is the "sticky" payload that lets F1 Quiz Abandonment
// personalize emails ("Hi {{ first_name|default:'there' }}…") and that
// gives nurture flows context even when the user never finishes.
async function fireStartedQuiz(email, answers) {
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return;
  const dedupeKey = 'klaviyo_started_quiz_' + email;
  if (localStorage.getItem(dedupeKey)) return;

  const profileAttrs = { email };
  if (answers && answers.firstName) {
    profileAttrs.first_name = String(answers.firstName).slice(0, 80);
  }
  const draftProps = buildDraftProfileProps(answers);
  if (Object.keys(draftProps).length > 0) {
    profileAttrs.properties = draftProps;
  }

  try {
    const resp = await fetch(
      'https://a.klaviyo.com/client/events/?company_id=' + encodeURIComponent(KLAVIYO_COMPANY_ID),
      {
        method: 'POST',
        headers: {
          'revision': '2024-10-15',
          'content-type': 'application/json'
        },
        body: JSON.stringify({
          data: {
            type: 'event',
            attributes: {
              properties: { step: 'contact' },
              metric: { data: { type: 'metric', attributes: { name: 'Started Quiz' } } },
              profile: { data: { type: 'profile', attributes: profileAttrs } }
            }
          }
        })
      }
    );
    if (resp.ok || resp.status === 202) {
      localStorage.setItem(dedupeKey, '1');
    } else {
      console.warn('[klaviyo] Started Quiz non-OK:', resp.status);
    }
  } catch (err) {
    // Never break the quiz flow on a Klaviyo failure
    console.warn('[klaviyo] Started Quiz failed:', err && err.message);
  }
}

// Profile-only patch — used when the user changes answers AFTER we've
// already captured their email (e.g. clicks Back to change a symptom).
// The Started Quiz event is deduped per-email, so subsequent edits would
// be invisible to Klaviyo without this. No event fires, just a profile
// upsert via the public client API. Throttled by a 2s debounce in the
// caller so we don't hammer Klaviyo on every keystroke.
async function patchKlaviyoProfile(email, answers) {
  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return;
  const profileAttrs = { email };
  if (answers && answers.firstName) {
    profileAttrs.first_name = String(answers.firstName).slice(0, 80);
  }
  const draftProps = buildDraftProfileProps(answers);
  if (Object.keys(draftProps).length > 0) {
    profileAttrs.properties = draftProps;
  }
  try {
    await fetch(
      'https://a.klaviyo.com/client/profiles/?company_id=' + encodeURIComponent(KLAVIYO_COMPANY_ID),
      {
        method: 'POST',
        headers: {
          'revision': '2024-10-15',
          'content-type': 'application/json'
        },
        body: JSON.stringify({
          data: { type: 'profile', attributes: profileAttrs }
        })
      }
    );
  } catch (err) {
    console.warn('[klaviyo] profile patch failed:', err && err.message);
  }
}

// Convert a US phone like "(555) 123-4567" to Klaviyo's required E.164 format "+15551234567"
function toE164(phone) {
  const digits = (phone || '').replace(/\D/g, '');
  if (digits.length === 10) return '+1' + digits;
  if (digits.length === 11 && digits.startsWith('1')) return '+' + digits;
  return null;
}

// Server-side submit pipeline. Replaces the old client-side Klaviyo call:
// the private API key + service-role Supabase writes live in /api/quiz/submit.
//
// We POST only sanitized fields — never any words that could expose PHI
// (no "menopause", "HRT", "hormone replacement therapy", etc.). The server
// fan-outs the call to Supabase + Klaviyo profile-import + Klaviyo subscribe
// using Promise.allSettled so Klaviyo flakes never break the quiz UX.
async function submitQuizToServer(answers) {
  if (!answers || !answers.email) return;

  // Dedupe — don't re-submit if the user lands back on /quiz with the same answers
  const dedupeKey = 'quiz_submitted_' + answers.email;
  if (localStorage.getItem(dedupeKey)) return;

  // Derive summary fields from the raw answers WITHOUT leaking medical jargon.
  // primary_symptom / hormone_stage are kept as opaque slugs (e.g. "stage_a")
  // assigned by the quiz UI — never the human-readable "perimenopause" etc.
  // Birthday is OPTIONAL — if the user left it blank or partially filled, omit it.
  const birthdayCheck = validateBirthday(answers.birthday);
  const birthdayISO = birthdayCheck.state === 'ok' ? birthdayCheck.iso : null;
  const payload = {
    email: answers.email,
    firstName: answers.firstName || null,
    primary_symptom: Array.isArray(answers.symptoms) ? (answers.symptoms[0] || null) : null,
    hormone_stage: answers.stage || null,
    symptom_score: Array.isArray(answers.symptoms) ? answers.symptoms.length : null,
    recommended_product: answers.recommended_product || null,
    birthday: birthdayISO,
    responses: answers
  };

  try {
    const resp = await fetch('/api/quiz/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    if (resp.ok) {
      localStorage.setItem(dedupeKey, '1');
      // Quiz is in the books — sticky draft is no longer useful, wipe it
      // so a return visit starts fresh.
      clearDraft();
      // Sanitized conversion event — no medical info, just signals "form completed".
      if (typeof window.trackCompleteRegistration === 'function') {
        window.trackCompleteRegistration();
      }
    } else {
      console.warn('[quiz/submit] non-OK response:', resp.status);
    }
  } catch (err) {
    // Never break the quiz flow on a network failure
    console.warn('[quiz/submit] failed:', err && err.message);
  }
}

function Quiz() {
  // Hydrate from a saved draft so partial sessions survive reload + return
  // visits. loadDraft() handles its own TTL + corruption checks.
  const draft = React.useMemo(() => loadDraft(), []);
  const [idx, setIdx] = useState(() => {
    if (!draft) return 0;
    const want = typeof draft.idx === 'number' ? draft.idx : 0;
    return Math.min(Math.max(want, 0), STEPS.length - 1);
  });
  const [answers, setAnswers] = useState(() => (draft && draft.answers) || {});
  const [done, setDone] = useState(false);

  // Persist the draft on every state change while the quiz is in progress.
  React.useEffect(() => {
    if (!done) saveDraft(answers, idx);
  }, [answers, idx, done]);

  // Re-sync the Klaviyo profile when the user edits answers AFTER we've
  // already captured their email. Debounced 2s so we don't hammer Klaviyo
  // on every click. No-op until email validates.
  React.useEffect(() => {
    const email = answers.email || '';
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return;
    if (!localStorage.getItem('klaviyo_started_quiz_' + email)) return; // initial event hasn't fired yet
    const t = setTimeout(() => { patchKlaviyoProfile(email, answers); }, 2000);
    return () => clearTimeout(t);
  }, [answers]);

  const step = STEPS[idx];
  const total = STEPS.length;
  const progress = done ? 100 : ((idx) / total) * 100;

  const value = answers[step?.key];
  // Birthday lives outside the STEPS array — it's an optional sub-field of the
  // contact step. Validate it alongside the required name/email/phone fields.
  const birthdayResult = validateBirthday(answers.birthday);
  const canContinue = (() => {
    if (!step) return false;
    if (step.kind === 'single') return !!value;
    if (step.kind === 'multi') return Array.isArray(value) && value.length > 0;
    if (step.kind === 'text') return typeof value === 'string' && /\S+@\S+\.\S+/.test(value);
    if (step.kind === 'contact') {
      const fn = (answers.firstName || '').trim();
      const em = answers.email || '';
      const ph = (answers.phone || '').replace(/\D/g, '');
      const requiredOk = fn.length > 0 && /\S+@\S+\.\S+/.test(em) && ph.length === 10;
      // Birthday is REQUIRED (needed by OpenLoop for clinical intake).
      // Only fully-valid birthdays unlock the submit button.
      const birthdayOk = birthdayResult.state === 'ok';
      // Notice-at-Collection + 18+ affirmation are REQUIRED for CCPA/CPRA
      // and the Terms eligibility statement. Both must be explicitly ticked
      // (audit findings H-17, M-22).
      const consentOk = answers.consentNoticeAck === true && answers.adultAck === true && answers.telehealthConsent === true;
      return requiredOk && birthdayOk && consentOk;
    }
    return false;
  })();

  const setSingle = (v) => setAnswers({ ...answers, [step.key]: v });
  const toggleMulti = (v) => {
    const cur = Array.isArray(value) ? value.slice() : [];
    const i = cur.indexOf(v);
    if (i >= 0) cur.splice(i, 1); else cur.push(v);
    setAnswers({ ...answers, [step.key]: cur });
  };
  const setText = (e) => setAnswers({ ...answers, [step.key]: e.target.value });

  const next = () => {
    if (idx < total - 1) setIdx(idx + 1);
    else setDone(true);
  };
  const back = () => idx > 0 && setIdx(idx - 1);

  // On completion: persist to localStorage (results.html reads this) + subscribe to Klaviyo
  React.useEffect(() => {
    if (done) {
      try {
        localStorage.setItem('herestrogen_quiz', JSON.stringify(answers));
      } catch (e) { /* storage disabled — fall back to defaults */ }
      // Fire-and-forget — quiz UX is independent of the server response
      submitQuizToServer(answers);
    }
  }, [done, answers]);

  if (done) {
    return (
      <div className="shell">
        <div className="progress-shell">
          <span>Step {total} of {total}</span>
          <div className="progress-bar"><div className="progress-fill" style={{ width: '100%' }}></div></div>
          <span>100%</span>
        </div>
        <div className="finish">
          <div className="finish-badge">✓</div>
          <h1>Thanks — your intake has been <em>submitted</em>.</h1>
          <p>
            A licensed clinician via our medical partner, OpenLoop Health,
            will review your responses — typically within 1&ndash;2 business days.
            Treatment is subject to clinical appropriateness and is not
            guaranteed; your clinician may decline if hormone therapy is not
            suitable for you.
          </p>
          <a href="results.html" className="btn btn-primary">View my next steps →</a>
          <div className="footnote">A clinician will respond by email</div>
        </div>
      </div>
    );
  }

  return (
    <div className="shell">
      <div className="progress-shell">
        <span>Step {idx + 1} of {total}</span>
        <div className="progress-bar"><div className="progress-fill" style={{ width: progress + '%' }}></div></div>
        <span>{Math.round(progress)}%</span>
      </div>

      <div className="step">
        <h1>{step.title}</h1>
        <p className="step-intro">{step.intro}</p>

        {step.kind === 'single' && (
          <div className="choices">
            {step.options.map(o => (
              <button
                key={o.v}
                className={'choice' + (value === o.v ? ' selected' : '')}
                onClick={() => setSingle(o.v)}
              >
                <span>
                  <div>{o.label}</div>
                  {o.note && <div className="choice-note">{o.note}</div>}
                </span>
                <span className="check">✓</span>
              </button>
            ))}
          </div>
        )}

        {step.kind === 'multi' && (
          <div className={step.grid ? 'symptom-grid' : 'choices'}>
            {step.options.map(o => {
              const sel = Array.isArray(value) && value.indexOf(o.v) >= 0;
              return (
                <button
                  key={o.v}
                  className={'choice' + (sel ? ' selected' : '')}
                  onClick={() => toggleMulti(o.v)}
                >
                  <span>{o.label}</span>
                  <span className="check">✓</span>
                </button>
              );
            })}
          </div>
        )}

        {step.kind === 'text' && (
          <div className="field">
            <label>{step.label}</label>
            <input
              type="email"
              placeholder={step.placeholder}
              value={value || ''}
              onChange={setText}
              autoFocus
            />
          </div>
        )}

        {step.kind === 'contact' && (
          <div>
            <div className="field">
              <label>First name</label>
              <input
                type="text"
                placeholder="Jane"
                value={answers.firstName || ''}
                onChange={(e) => setAnswers({ ...answers, firstName: e.target.value })}
                autoComplete="given-name"
                autoCapitalize="words"
                autoFocus
              />
            </div>
            <div className="field">
              <label>Email</label>
              <input
                type="email"
                placeholder="you@email.com"
                value={answers.email || ''}
                onChange={(e) => {
                  const v = e.target.value;
                  const nextAnswers = { ...answers, email: v };
                  setAnswers(nextAnswers);
                  // Fire Started Quiz once the email validates — this is the
                  // signal F1 Quiz Abandonment listens for. The helper is
                  // idempotent (localStorage dedupe) so re-typing won't re-fire.
                  // We pass the in-progress answers so the profile carries the
                  // sticky context (symptoms, stage, etc.) on first capture.
                  fireStartedQuiz(v, nextAnswers);
                }}
                autoComplete="email"
                inputMode="email"
              />
            </div>
            <div className="field">
              <label>Phone</label>
              <input
                type="tel"
                placeholder="(555) 123-4567"
                value={answers.phone || ''}
                onChange={(e) => setAnswers({ ...answers, phone: formatPhone(e.target.value) })}
                autoComplete="tel"
                inputMode="tel"
              />
              {/* TCPA-compliant SMS disclosure (audit finding H-16).
                  Tied to the SMS opt-in checkbox below so consent is opt-in
                  rather than implied. */}
              <label className="helper" style={{ display: 'flex', alignItems: 'flex-start', gap: 8, marginTop: 10, cursor: 'pointer', lineHeight: 1.5 }}>
                <input
                  type="checkbox"
                  checked={!!answers.smsOptIn}
                  onChange={(e) => setAnswers({ ...answers, smsOptIn: e.target.checked })}
                  style={{ marginTop: 3 }}
                />
                <span>
                  <strong>SMS opt-in (optional).</strong> By checking this box,
                  I agree to receive recurring marketing and care-related text
                  messages from HerEstrogen at the number above (sent via an
                  automated dialing system). Message frequency varies. Message
                  &amp; data rates may apply. Reply STOP to opt out, HELP for
                  help. Consent is <strong>not</strong> a condition of any
                  purchase. See our <a href="terms.html" target="_blank" rel="noopener">Terms</a> and <a href="privacy.html" target="_blank" rel="noopener">Privacy Policy</a>.
                </span>
              </label>
            </div>
            {/* REQUIRED — single point of capture. Used by OpenLoop for clinical
                intake (provider must verify candidacy by age) and by Klaviyo
                for birthday flows. Wrapped in fieldset/legend for screen-reader
                grouping (audit finding L-09). */}
            <fieldset className="field" style={{ border: 0, padding: 0, margin: 0 }}>
              <legend style={{ fontFamily: 'DM Mono, monospace', fontSize: 11, letterSpacing: '0.1em', textTransform: 'uppercase', color: 'var(--pink)', padding: 0 }}>Birthday</legend>
              <div className="helper">Required to verify your candidacy with a licensed provider</div>
              <div className="field-row3">
                <select
                  aria-label="Birth month"
                  value={(answers.birthday && answers.birthday.month) || ''}
                  onChange={(e) => setAnswers({
                    ...answers,
                    birthday: { ...(answers.birthday || {}), month: e.target.value }
                  })}
                >
                  <option value="">Month</option>
                  {MONTHS.slice(1).map((m, i) => (
                    <option key={i + 1} value={String(i + 1)}>{m}</option>
                  ))}
                </select>
                <select
                  aria-label="Birth day"
                  value={(answers.birthday && answers.birthday.day) || ''}
                  onChange={(e) => setAnswers({
                    ...answers,
                    birthday: { ...(answers.birthday || {}), day: e.target.value }
                  })}
                >
                  <option value="">Day</option>
                  {(() => {
                    const max = daysInMonth(
                      (answers.birthday && answers.birthday.month) || '',
                      (answers.birthday && answers.birthday.year) || ''
                    ) || 31;
                    const opts = [];
                    for (let d = 1; d <= max; d++) opts.push(<option key={d} value={String(d)}>{d}</option>);
                    return opts;
                  })()}
                </select>
                <select
                  aria-label="Birth year"
                  value={(answers.birthday && answers.birthday.year) || ''}
                  onChange={(e) => setAnswers({
                    ...answers,
                    birthday: { ...(answers.birthday || {}), year: e.target.value }
                  })}
                >
                  <option value="">Year</option>
                  {BIRTH_YEARS.map((y) => (
                    <option key={y} value={String(y)}>{y}</option>
                  ))}
                </select>
              </div>
              {birthdayResult.state === 'partial' && (
                <div className="field-error">Please complete all three fields.</div>
              )}
              {birthdayResult.state === 'invalid' && (
                <div className="field-error">Please enter a valid birthday.</div>
              )}
            </fieldset>

            {/* Notice at Collection + 18+ affirmation (audit findings H-17, M-22).
                Required to advance — see canContinue() above. */}
            <div className="field" style={{ marginTop: 24, paddingTop: 18, borderTop: '1px solid var(--line)' }}>
              <label className="helper" style={{ display: 'flex', alignItems: 'flex-start', gap: 8, cursor: 'pointer', lineHeight: 1.5 }}>
                <input
                  type="checkbox"
                  checked={!!answers.consentNoticeAck}
                  onChange={(e) => setAnswers({ ...answers, consentNoticeAck: e.target.checked })}
                  style={{ marginTop: 3 }}
                  required
                />
                <span>
                  I have read the <a href="privacy.html" target="_blank" rel="noopener">Notice at Collection &amp; Privacy Policy</a> and the <a href="terms.html" target="_blank" rel="noopener">Terms of Service</a>, including how my information is used and shared. I am providing consumer health information voluntarily (per Washington MHMDA and similar state laws where applicable).
                </span>
              </label>
              <label className="helper" style={{ display: 'flex', alignItems: 'flex-start', gap: 8, marginTop: 12, cursor: 'pointer', lineHeight: 1.5 }}>
                <input
                  type="checkbox"
                  checked={!!answers.adultAck}
                  onChange={(e) => setAnswers({ ...answers, adultAck: e.target.checked })}
                  style={{ marginTop: 3 }}
                  required
                />
                <span>I confirm that I am at least 18 years old.</span>
              </label>
              <label className="helper" style={{ display: 'flex', alignItems: 'flex-start', gap: 8, marginTop: 12, cursor: 'pointer', lineHeight: 1.5 }}>
                <input
                  type="checkbox"
                  checked={!!answers.telehealthConsent}
                  onChange={(e) => setAnswers({ ...answers, telehealthConsent: e.target.checked })}
                  style={{ marginTop: 3 }}
                  required
                />
                <span>
                  I consent to receive telehealth services from our medical partner, OpenLoop Health. I have reviewed the <a href="https://openloophealth.com/telehealth-consent" target="_blank" rel="noopener">OpenLoop Telehealth Informed Consent</a> and HerEstrogen's <a href="refunds.html" target="_blank" rel="noopener">Cancellation &amp; Refund Policy</a>.
                </span>
              </label>
            </div>
          </div>
        )}

        <div className="actions">
          <button className="btn btn-back" onClick={back} disabled={idx === 0} style={{ visibility: idx === 0 ? 'hidden' : 'visible' }}>
            ← Back
          </button>
          <button className="btn btn-primary" onClick={next} disabled={!canContinue}>
            {idx === total - 1 ? 'See if I qualify →' : 'Continue →'}
          </button>
        </div>

        <div className="footnote">Your answers are protected per our Privacy Policy</div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<Quiz />);
</script>

</body>
</html>
